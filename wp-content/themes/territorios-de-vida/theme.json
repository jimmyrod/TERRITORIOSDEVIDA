{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "760px",
      "wideSize": "1200px"
    },
    "color": {
      "palette": [
        { "slug": "selva-oscuro", "color": "#1B4332", "name": "Selva oscuro" },
        { "slug": "bosque-medio", "color": "#2D6A4F", "name": "Bosque medio" },
        { "slug": "hoja", "color": "#52B788", "name": "Hoja" },
        { "slug": "menta", "color": "#D8F3DC", "name": "Menta" },
        { "slug": "dorado-tierra", "color": "#C8961E", "name": "Dorado tierra" },
        { "slug": "cafe-tierra", "color": "#7A4A1E", "name": "Cafe tierra" },
        { "slug": "azul-agua", "color": "#219EBC", "name": "Azul agua" },
        { "slug": "naranja", "color": "#F4A261", "name": "Naranja" },
        { "slug": "blanco", "color": "#FFFFFF", "name": "Blanco" },
        { "slug": "texto", "color": "#1F2933", "name": "Texto" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "\"Playfair Display\", Georgia, serif",
          "name": "Playfair Display",
          "slug": "display"
        },
        {
          "fontFamily": "\"Inter\", \"Montserrat\", system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
          "name": "Inter",
          "slug": "inter"
        }
      ]
    },
    "spacing": {
      "spacingScale": {
        "steps": 0
      },
      "spacingSizes": [
        { "slug": "20", "size": "1.25rem", "name": "20" },
        { "slug": "32", "size": "2rem", "name": "32" },
        { "slug": "48", "size": "3rem", "name": "48" },
        { "slug": "72", "size": "4.5rem", "name": "72" }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "#F7FAF8",
      "text": "#1F2933"
    },
    "typography": {
      "fontFamily": "\"Inter\", \"Montserrat\", system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
      "fontSize": "18px",
      "lineHeight": "1.65"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "\"Playfair Display\", Georgia, serif",
          "fontWeight": "700",
          "lineHeight": "1.1"
        },
        "color": {
          "text": "#1B4332"
        }
      },
      "link": {
        "color": {
          "text": "#1B4332"
        }
      }
    }
  }
}

